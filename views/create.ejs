<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Додати Ресторан</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white text-center py-3">
                        <h4 class="mb-0">✨ Новий Ресторан</h4>
                    </div>
                    <div class="card-body p-4">
                        <form action="/restaurants/create" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Назва ресторану</label>
                                <input type="text" name="name" class="form-control" placeholder="Наприклад: Пузата Хата" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Тип кухні</label>
                                <select name="cuisineType" class="form-select" required>
                                    <option value="" disabled selected>Оберіть кухню...</option>
                                    <option value="Ukrainian">Українська</option>
                                    <option value="Italian">Італійська</option>
                                    <option value="Asian">Азійська</option>
                                    <option value="French">Французька</option>
                                    <option value="Other">Інша</option>
                                </select>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success text-uppercase fw-bold">Зберегти</button>
                                <a href="/restaurants" class="btn btn-light">Скасувати</a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>